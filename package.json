    "build": "npm run build:client",
    "build:client": "tsc -p tsconfig.client.json && vite build",
    "typecheck": "tsc -p tsconfig.client.json",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.11",
    "@mui/lab": "^7.0.0-beta.10",
    "@mui/material": "^7.3.11",
    "@mui/x-charts": "^7.29.1",
    "@mui/x-data-grid": "^8.28.7",
    "@mui/x-data-grid-premium": "^8.28.7",
    "@mui/x-data-grid-pro": "^8.28.7",
    "@mui/x-date-pickers": "^7.29.4",
    "@mui/x-date-pickers-pro": "^7.29.4",
    "@mui/x-tree-view": "^7.29.10",
    "dayjs": "^1.11.21",
    "firebase": "^12.15.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-dropzone": "^14.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "3.8.3",
    "typescript": "~6.0.2",
